# ──────────────────────────────────────────────────────────────
# BHAF MarketBridge — environment variables
#
# Copy to .env.local for local development. On Vercel, add the
# same variables under Project Settings → Environment Variables.
# Without DATABASE_URL the site still runs against mock data.
# ──────────────────────────────────────────────────────────────

# Database (Postgres) — required for real auth, uploads, audit log.
# Get a free Postgres at https://neon.tech in ~30 seconds.
DATABASE_URL=

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Optional OAuth providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Optional Resend magic-link email provider
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="BHAF MarketBridge <noreply@bhaf.example>"

# Transactional email (Resend)
RESEND_API_KEY=
EMAIL_FROM="BHAF MarketBridge <noreply@bhaf.example>"

# Object storage (Vercel Blob). Generate a token in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# Distributed rate limiting (Upstash Redis). Free tier covers all dev work.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Anthropic (Asha assistant). Any of these three names is accepted.
ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=
# ClaudeAPIKeyMarketBridge=
